# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
.env
*.egg-info/
dist/
build/

# uv
.python-version

# dbt
transform/target/
transform/dbt_packages/
transform/logs/
transform/.user.yml

# Terraform
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
!infra/envs/dev/terraform.tfvars.example
!infra/envs/prod/terraform.tfvars.example
.terraform.lock.hcl

# Secrets  -  never commit
# Service-account keys, credentials, any JSON key material. No exceptions  -  the project
# uses no tracked .json config, so a blanket ignore is safe and prevents key leaks.
*.json
service-account*.json
*-key.json
*credentials*.json
*.pem
*.p12
*.key

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp

# Logs
*.log
logs/

# Docker
.dockerignore
